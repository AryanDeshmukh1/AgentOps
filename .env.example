# ====================================================
# AgentOps Environment Variables
# ====================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to git.
# ====================================================

# --- Application ---
NODE_ENV=development
LOG_LEVEL=info

# --- Backend Server ---
BACKEND_PORT=4000
BACKEND_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:4000
VITE_WS_URL=ws://localhost:4000

# --- Python Agent System ---
AGENTS_PORT=5000
AGENTS_HOST=0.0.0.0

# --- AWS Configuration ---
AWS_REGION=ca-central-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# --- AWS Resources (already created) ---
# DynamoDB Tables
DYNAMODB_PIPELINES_TABLE=AgentOps-Pipelines
DYNAMODB_AGENT_DECISIONS_TABLE=AgentOps-AgentDecisions
DYNAMODB_APPROVALS_TABLE=AgentOps-Approvals
DYNAMODB_INCIDENTS_TABLE=AgentOps-Incidents
DYNAMODB_METRICS_TABLE=AgentOps-Metrics
DYNAMODB_DEPLOY_LOCKS_TABLE=AgentOps-DeployLocks

# SQS Queue URLs (replace YOUR_ACCOUNT_ID with your AWS account ID)
SQS_REVIEW_QUEUE_URL=https://sqs.ca-central-1.amazonaws.com/YOUR_ACCOUNT_ID/AgentOps-ReviewQueue
SQS_TEST_QUEUE_URL=https://sqs.ca-central-1.amazonaws.com/YOUR_ACCOUNT_ID/AgentOps-TestQueue
SQS_APPROVAL_QUEUE_URL=https://sqs.ca-central-1.amazonaws.com/YOUR_ACCOUNT_ID/AgentOps-ApprovalQueue
SQS_DEPLOY_QUEUE_URL=https://sqs.ca-central-1.amazonaws.com/YOUR_ACCOUNT_ID/AgentOps-DeployQueue
SQS_INCIDENT_QUEUE_URL=https://sqs.ca-central-1.amazonaws.com/YOUR_ACCOUNT_ID/AgentOps-IncidentQueue
SQS_DEAD_LETTER_QUEUE_URL=https://sqs.ca-central-1.amazonaws.com/YOUR_ACCOUNT_ID/AgentOps-DeadLetter

# S3 Bucket
S3_ARTIFACTS_BUCKET=agentops-artifacts-aryan2026

# --- Gemini API ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_PRIMARY=gemini-2.5-flash
GEMINI_MODEL_LIGHT=gemini-2.5-flash-lite
GEMINI_RATE_LIMIT_RPM=10
GEMINI_RATE_LIMIT_LIGHT_RPM=15

# --- GitHub Integration ---
GITHUB_WEBHOOK_SECRET=generate_a_random_string_here
GITHUB_APP_ID=your_github_app_id
GITHUB_APP_PRIVATE_KEY=your_github_app_private_key
GITHUB_INSTALLATION_ID=your_installation_id

# --- Agent Configuration ---
REVIEW_SCORE_THRESHOLD=70
TEST_PASS_RATE_THRESHOLD=80
INCIDENT_Z_SCORE_THRESHOLD=3.0
DEPLOY_HEALTH_CHECK_RETRIES=3
DEPLOY_HEALTH_CHECK_INTERVAL_SECONDS=10
